<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Animated data story</title>
    <link href="/css/style.css" rel="stylesheet">
    <script src="/js/index.js"></script>
</head>

<body class="w-full h-auto bg-black">
    <!-- top navbar -->
    <nav class="w-full h-auto flex flex-row items-center justify-between p-3 border-b border-b-white/50 bg-[#2e2e2c]">
        <div class="flex flex-row gap-2 items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 20 20" class="fill-current">
                <rect width="8" height="8" x="2" y="2" rx="2" ry="2" fill="#6963a6"></rect>
                <rect width="8" height="8" x="12" y="2" rx="2" ry="2" fill="#8884b0"></rect>
                <rect width="8" height="8" x="12" y="12" rx="2" ry="2" fill="#9e9cb8"></rect>
                <rect width="8" height="8" x="2" y="12" rx="2" ry="2" fill="#8884b0"></rect>
            </svg>
            <h1 class="text-md font-semibold">Infograph</h1>
        </div>
        <a href="/">
            <button
                class="flex flex-row items-center justify-center gap-1 px-4 py-2 text-sm font-semibold border border-white/50 rounded-sm">
                <svg width="10" height="10" viewBox="0 0 20 20">
                    <line x1="2" y1="10" x2="10" y2="2" stroke="white" stroke-width="4" stroke-linecap="round"
                        fill="none">
                    </line>
                    <line x1="2" y1="10" x2="10" y2="18" stroke="white" stroke-width="4" stroke-linecap="round"
                        fill="none">
                    </line>
                </svg>
                All stories
            </button>
        </a>
    </nav>
    <% let type=item?.chartType[0]; let bgColor, textColor, symbolId, vBox; if(type==="bar" ){ bgColor="bg-[#b1b1bd]" ;
        borderColor="border-[#6560a6]" ; textColor="text-[#6560a6]" ; } else if(type==="line" ){ bgColor="bg-[#a9b8b2]"
        ; borderColor="border-[#207a5e]" ; textColor="text-[#207a5e]" ; }else if(type==="pie" ){ bgColor="bg-[#bab2a4]"
        ; borderColor="border-[#8f5d1b]" ; textColor="text-[#8f5d1b]" ; } %>
        <section class="w-full h-auto bg-black p-8">
            <button class="px-3 <%= bgColor %> <%= textColor %> tracking-wide font-semibold rounded-md capitalize">
                <%= type%> chart
            </button>
            <h1 class="font-bold tracking-wider text-2xl mt-4 line-clamp-1">
                <%= item.title %>
            </h1>
            <div class="<%= bgColor %> w-40 h-0.5 rounded-full my-2"></div>
            <h3 class="font-semibold text-white/50 px-2 border-l-2 <%= borderColor %> line-clamp-1">
                <%=item.insight%>
            </h3>
            <!-- data count -->
            <div class="flex flex-row w-full gap-8 mt-6 items-center justify-evenly">
                <% const values=item.info.map(d=> d.value); %>
                    <div
                        class="flex flex-col flex-1 items-center justify-center p-4 rounded-xl  border border-white/20 bg-[#2e2e2c]">
                        <h1 class="font-semibold text-[1.5rem]">
                            <%= values.length %>
                        </h1>
                        <h3 class="text-white/50 font-semibold">Categories</h3>
                    </div>
                    <div
                        class="flex flex-col flex-1 items-center justify-center p-4 rounded-xl  border border-white/20 bg-[#2e2e2c]">
                        <h1 class="font-semibold text-[1.5rem]">
                            <%= Math.max(...values) %>
                                <%= item.unit %>
                        </h1>
                        <h3 class="text-white/50 font-semibold">Highest</h3>
                    </div>
                    <div
                        class="flex flex-col flex-1 items-center justify-center p-4 rounded-xl  border border-white/20 bg-[#2e2e2c]">
                        <h1 class="font-semibold text-[1.5rem]">
                            <%= Math.min(...values) %>
                                <%= item.unit %>
                        </h1>
                        <h3 class="text-white/50 font-semibold">Lowest</h3>
                    </div>
                    <div
                        class="flex flex-col flex-1 items-center justify-center p-4 rounded-xl  border border-white/20 bg-[#2e2e2c]">
                        <h1 class="font-semibold text-[1.5rem]">
                            <%= values.reduce((acc, curr)=> acc + curr, 0) %> <%= item.unit %>
                        </h1>
                        <h3 class="text-white/50 font-semibold">Total</h3>
                    </div>
            </div>
            <!-- chart div -->
            <div class="w-full h-140 p-6 bg-[#2e2e2c] my-10 rounded-xl border border-white/20">
                <% let active=item.chartType[0]; %>
                    <div class="flex flex-row gap-2">
                        <button id="chartBtn" onclick="changeChart('bar')"
                            class="flex flex-row items-center justify-center gap-1 px-4 py-2 text-sm font-semibold border border-white/50 rounded-sm <%= active === 'bar' ? 'bg-black' : 'bg-transparent' %>"
                            data-type="bar">
                            <svg width="20" height="20" viewBox="0 0 20 20">
                                <line x1="4" y1="18" x2="4" y2="12" stroke="white" stroke-linecap="round"
                                    stroke-width="4"></line>
                                <line x1="10" y1="18" x2="10" y2="8" stroke="white" stroke-linecap="round"
                                    stroke-width="4">
                                </line>
                                <line x1="16" y1="18" x2="16" y2="4" stroke="white" stroke-linecap="round"
                                    stroke-width="4">
                                </line>
                            </svg>
                            Bar
                        </button>
                        <button id="chartBtn" onclick="changeChart('line')"
                            class="flex flex-row items-center justify-center gap-1 px-4 py-2 text-sm font-semibold border border-white/50 rounded-sm <%= active === 'line' ? 'bg-black' : 'bg-transparent' %>"
                            data-type="line">
                            <svg width="20" height="20" viewBox="0 0 20 20">
                                <polyline points="2,18 5,10 9,14 13,8 17,13" stroke="white" stroke-width="2"
                                    stroke-linecap="round" fill="none" stroke-linejoin="round"></polyline>
                            </svg>
                            Line
                        </button>
                        <button id="chartBtn" onclick="changeChart('pie')"
                            class="flex flex-row items-center justify-center gap-1 px-4 py-2 text-sm font-semibold border border-white/50 rounded-sm <%= active === 'pie' ? 'bg-black' : 'bg-transparent' %>"
                            data-type="pie">
                            <svg class="bg-white rounded-full" width="20" height="20" viewBox="0 0 20 20">
                                <circle cx="10" cy="10" r="3.7" fill="none" stroke="#2e2e2c" stroke-dasharray="18 20"
                                    stroke-width="8"></circle>
                            </svg>
                            Pie
                        </button>
                    </div>
                    <div id="typeCharts" class="flex items-center justify-center w-full h-full pt-10">
                        <!-- graph accordingly -->
                         <% const vals=item.info.map(d=> d.value);
                        const maxVal = Math.max(...vals);
                        const chartH = 200; let gap; let startX; let colors; %>
                        
                    <!-- bar -->
                    <div data-type="bar" class="w-[90%] h-full <%= active === 'bar' ? 'block' : 'hidden' %>">
                             <% const barW = Math.min(60, Math.floor(520 / vals.length) - 20);
                            gap = Math.floor(520 / vals.length);
                            startX = 80;
                            %>
                            <svg width="100%" height="100%" viewBox="0 0 680 280">
                                <line x1="60" y1="30" x2="640" y2="30" stroke="rgba(255,255,255,0.06)"
                                    stroke-width="1" />
                                <line x1="60" y1="80" x2="640" y2="80" stroke="rgba(255,255,255,0.06)"
                                    stroke-width="1" />
                                <line x1="60" y1="130" x2="640" y2="130" stroke="rgba(255,255,255,0.06)"
                                    stroke-width="1" />
                                <line x1="60" y1="180" x2="640" y2="180" stroke="rgba(255,255,255,0.06)"
                                    stroke-width="1" />
                                <line x1="60" y1="230" x2="640" y2="230" stroke="rgba(255,255,255,0.12)"
                                    stroke-width="1" />
                                <% colors=['#7f77dd','#1d9e75','#d85a30','#ba7517','#888780','#3266ad','#639922'];
                                    %>
                                    <% item.info.forEach((d, i)=> {
                                        const barH = Math.round((d.value / maxVal) * chartH);
                                        const x = startX + i * gap;
                                        const y = 230 - barH;
                                        const cx = x + barW / 2;
                                        const color = colors[i % colors.length];
                                        %>
                                        <rect x="<%= x %>" y="<%= y %>" width="<%= barW %>" height="<%= barH %>" rx="4"
                                            fill="<%= color %>cc" />
                                        <text x="<%= cx %>" y="<%= y - 8 %>" text-anchor="middle" font-size="12"
                                            font-weight="700" fill="<%= color %>">
                                            <%= d.value %>
                                                <%= item.unit %>
                                        </text>
                                        <text x="<%= cx %>" y="248" text-anchor="middle" font-size="12" fill="#aaa">
                                            <%= d.label %>
                                        </text>
                                        <% }) %>
                            </svg>
                    </div>
                    <!-- line -->
                    <div data-type="line" class="w-[90%] h-full <%= active === 'line' ? 'block' : 'hidden' %>">
<%
    gap = Math.floor(520 / (item.info.length - 1));
    startX = 110;
    const points = item.info.map((d, i) => {
        const x = startX + i * gap;
        const y = 230 - Math.round((d.value / maxVal) * chartH);
        return { x, y, label: d.label, value: d.value };
    });
    const polyPts = points.map(p => p.x + ',' + p.y).join(' ');
%>
<svg width="100%" viewBox="0 0 680 280">
    <line x1="60" y1="30"  x2="640" y2="30"  stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
    <line x1="60" y1="80"  x2="640" y2="80"  stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
    <line x1="60" y1="130" x2="640" y2="130" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
    <line x1="60" y1="180" x2="640" y2="180" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
    <line x1="60" y1="230" x2="640" y2="230" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
    <polyline points="<%- polyPts %>" fill="none" stroke="#7f77dd" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
    <% points.forEach(p => { %>
        <circle cx="<%= p.x %>" cy="<%= p.y %>" r="6" fill="#7f77dd"/>
        <text x="<%= p.x %>" y="<%= p.y - 12 %>" text-anchor="middle" font-size="12" font-weight="700" fill="#7f77dd"><%= p.value %><%= item.unit %></text>
        <text x="<%= p.x %>" y="248" text-anchor="middle" font-size="12" fill="#aaa"><%= p.label %></text>
    <% }) %>
</svg>
                    </div>
                    <!-- pie -->
                    <div data-type="pie" class="w-[90%] h-full <%= active === 'pie' ? 'block' : 'hidden' %>">
<%
    total = vals.reduce((a, b) => a + b, 0);
    colors = ['#7f77dd','#1d9e75','#d85a30','#ba7517','#888780','#3266ad','#639922'];
    const cx = 220, cy = 150, R = 110, r = 65;
    let angle = -Math.PI / 2;
    const slices = item.info.map((d, i) => {
        const slice = (d.value / total) * 2 * Math.PI;
        const startA = angle;
        angle += slice;
        const x1 = cx + R * Math.cos(startA), y1 = cy + R * Math.sin(startA);
        const x2 = cx + R * Math.cos(angle),  y2 = cy + R * Math.sin(angle);
        const ix1 = cx + r * Math.cos(startA), iy1 = cy + r * Math.sin(startA);
        const ix2 = cx + r * Math.cos(angle),  iy2 = cy + r * Math.sin(angle);
        const large = slice > Math.PI ? 1 : 0;
        const path = `M${x1.toFixed(1)},${y1.toFixed(1)} A${R},${R} 0 ${large},1 ${x2.toFixed(1)},${y2.toFixed(1)} L${ix2.toFixed(1)},${iy2.toFixed(1)} A${r},${r} 0 ${large},0 ${ix1.toFixed(1)},${iy1.toFixed(1)} Z`;
        const pct = Math.round(d.value / total * 100);
        const barW = Math.round(160 * d.value / vals[0]);
        return { path, color: colors[i % colors.length], label: d.label, value: d.value, pct, barW };
    });
%>
<svg width="100%" viewBox="0 0 680 300">
    <% slices.forEach(s => { %>
        <path d="<%- s.path %>" fill="<%= s.color %>cc"/>
    <% }) %>
    <text x="<%= cx %>" y="<%= cy + 5 %>" text-anchor="middle" font-size="13" font-weight="600" fill="#aaa"><%= item.unit %></text>
    <% slices.forEach((s, i) => { const ly = 68 + i * 42; %>
        <rect x="380" y="<%= ly %>" width="12" height="12" rx="2" fill="<%= s.color %>cc"/>
        <text x="400" y="<%= ly + 10 %>" font-size="12" fill="#aaa"><%= s.label %></text>
        <text x="560" y="<%= ly + 10 %>" font-size="12" font-weight="700" fill="<%= s.color %>"><%= s.pct %>%</text>
        <line x1="400" y1="<%= ly + 16 %>" x2="560"           y2="<%= ly + 16 %>" stroke="rgba(255,255,255,0.1)" stroke-width="2.5"/>
        <line x1="400" y1="<%= ly + 16 %>" x2="<%= 400 + s.barW %>" y2="<%= ly + 16 %>" stroke="<%= s.color %>" stroke-width="2.5" stroke-linecap="round"/>
    <% }) %>
</svg>
                    </div>
                    </div>
                    <div class="flex flex-row gap-4">
                        <button
                            class="flex flex-row items-center justify-center gap-1 px-4 py-2 text-sm font-semibold border border-white/50 rounded-sm">
                            <svg width="15" height="15" viewBox="0 0 20 20">
                                <line x1="3" y1="9" x2="6" y2="11" stroke="white" stroke-width="2"
                                    stroke-linecap="round" fill="none">
                                </line>
                                <line x1="3" y1="10" x2="0" y2="11" stroke="white" stroke-width="2"
                                    stroke-linecap="round" fill="none">
                                </line>
                                <circle cx="10" cy="10" r="8" stroke="white" stroke-width="2" stroke-dasharray="45 5"
                                    stroke-dashoffset="18" fill="none"></circle>
                            </svg>
                            Replay animation
                        </button>
                        <% let nextId=(Number(item.id) < data.length) ? Number(item.id) + 1 : 1; %>
                            <a href="/infographic/<%= nextId %>">
                                <button
                                    class="flex flex-row items-center justify-center gap-1 px-4 py-2 text-sm font-semibold border border-white/50 rounded-sm">Next
                                    story
                                    <svg width="10" height="10" viewBox="0 0 20 20">
                                        <line x1="16" y1="10" x2="6" y2="2" stroke="white" stroke-width="4"
                                            stroke-linecap="round" fill="none">
                                        </line>
                                        <line x1="16" y1="10" x2="6" y2="18" stroke="white" stroke-width="4"
                                            stroke-linecap="round" fill="none">
                                        </line>
                                    </svg>
                                </button>
                            </a>
                    </div>
        </section>
</body>

</html>