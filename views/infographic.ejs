<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Animated data story</title>
    <link href="/css/style.css" rel="stylesheet">
    <script src="/js/index.js"></script>
</head>

<body class="w-full h-auto bg-black">
    <!-- top navbar -->
    <nav
        class="w-full h-auto flex flex-row items-center justify-between px-4 py-2 border-b border-b-white/50 bg-[#2e2e2c]">
        <div class="flex flex-row gap-2 items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 20 20" class="fill-current">
                <rect width="8" height="8" x="2" y="2" rx="2" ry="2" fill="#6963a6"></rect>
                <rect width="8" height="8" x="12" y="2" rx="2" ry="2" fill="#8884b0"></rect>
                <rect width="8" height="8" x="12" y="12" rx="2" ry="2" fill="#9e9cb8"></rect>
                <rect width="8" height="8" x="2" y="12" rx="2" ry="2" fill="#8884b0"></rect>
            </svg>
            <h1 class="text-md font-semibold">Infograph</h1>
        </div>
        <a href="/">
            <button
                class="flex flex-row items-center justify-center gap-1 px-4 py-2 text-sm font-semibold border border-white/50 rounded-sm">
                <svg width="10" height="10" viewBox="0 0 20 20">
                    <line x1="2" y1="10" x2="10" y2="2" stroke="white" stroke-width="4" stroke-linecap="round"
                        fill="none">
                    </line>
                    <line x1="2" y1="10" x2="10" y2="18" stroke="white" stroke-width="4" stroke-linecap="round"
                        fill="none">
                    </line>
                </svg>
                All stories
            </button>
        </a>
    </nav>
    <% let type=item?.chartType[0]; let bgColor, textColor, symbolId, vBox; if(type==="bar" ){ bgColor="bg-[#b1b1bd]" ;
        borderColor="border-[#6560a6]" ; textColor="text-[#6560a6]" ; } else if(type==="line" ){ bgColor="bg-[#a9b8b2]"
        ; borderColor="border-[#207a5e]" ; textColor="text-[#207a5e]" ; }else if(type==="pie" ){ bgColor="bg-[#bab2a4]"
        ; borderColor="border-[#8f5d1b]" ; textColor="text-[#8f5d1b]" ; } %>

        <section class="w-full h-auto bg-black p-8 max-[700px]:p-4">
            <button
                class="px-3 <%= bgColor %> max-[700px]:text-sm <%= textColor %> tracking-wide font-semibold rounded-md capitalize">
                <%= type%> chart
            </button>
            <h1 class="font-bold tracking-wider text-2xl max-[700px]:text-xl max-[700px]:mt-2 mt-4 line-clamp-1">
                <%= item.title %>
            </h1>
            <div class="<%= bgColor %> w-[20%] h-0.5 rounded-full my-2"></div>
            <h3
                class="font-semibold text-white/50 max-[700px]:text-xs max-[514px]:line-clamp-2 px-2 border-l-2 <%= borderColor %> line-clamp-1">
                <%=item.insight%>
            </h3>
            <!-- data count -->
            <div
                class="flex flex-row w-full max-[700px]:gap-2 max-[400px]:flex-col gap-8 mt-6 items-center justify-evenly">
                <% const values=item.info.map(d=> d.value); %>
                    <div
                        class="flex flex-col flex-1 max-[400px]:w-full items-center justify-center p-4  max-[700px]:p-2 rounded-xl  border border-white/20 bg-[#2e2e2c]">
                        <h1 class="font-semibold text-[1.5rem] max-[700px]:md max-[510px]:text-sm">
                            <%= values.length %>
                        </h1>
                        <h3 class="text-white/50 font-semibold max-[700px]:text-xs">Categories</h3>
                    </div>
                    <div
                        class="flex flex-col flex-1 max-[400px]:w-full items-center max-[700px]:p-2 justify-center p-4 rounded-xl  border border-white/20 bg-[#2e2e2c]">
                        <h1 class="font-semibold max-[700px]:md text-[1.5rem] max-[510px]:text-sm">
                            <%= Math.max(...values) %>
                                <%= item.unit %>
                        </h1>
                        <h3 class="text-white/50 max-[700px]:text-xs font-semibold">Highest</h3>
                    </div>
                    <div
                        class="flex flex-col flex-1 max-[700px]:p-2 max-[400px]:w-full items-center justify-center p-4 rounded-xl  border border-white/20 bg-[#2e2e2c]">
                        <h1 class="font-semibold max-[700px]:text-md text-[1.5rem] max-[510px]:text-sm">
                            <%= Math.min(...values) %>
                                <%= item.unit %>
                        </h1>
                        <h3 class="text-white/50 max-[700px]:text-xs font-semibold">Lowest</h3>
                    </div>
                    <div
                        class="flex flex-col flex-1 max-[400px]:w-full items-center max-[700px]:p-2 justify-center p-4 rounded-xl  border border-white/20 bg-[#2e2e2c]">
                        <h1 class="font-semibold text-[1.5rem] max-[700px]:text-md max-[510px]:text-sm">
                            <%= values.reduce((acc, curr)=> acc + curr, 0) %> <%= item.unit %>
                        </h1>
                        <h3 class="text-white/50 font-semibold max-[700px]:text-xs">Total</h3>
                    </div>
            </div>
            <!-- chart div -->
            <div
                class="w-full h-150 max-[800px]:h-100 max-[500px]:h-80 max-[400px]:h-60 p-6 bg-[#2e2e2c] my-6 max-[350px]:p-2 rounded-xl border flex flex-col items-start justify-between border-white/20">
                <% let active=item.chartType[0]; %>
                    <div class="flex flex-row gap-2 max-[350px]:gap-1">
                        <button id="chartBtn"
                            onclick="changeChart('bar'); document.querySelectorAll('#barSvg animate').forEach(a => a.beginElement())"
                            class="flex flex-row max-[350px]:px-2 max-[350px]:py-1 max-[350px]:text-xs items-center justify-center gap-1 px-4 py-2 text-sm font-semibold border border-white/50 rounded-sm <%= active === 'bar' ? 'bg-black' : 'bg-transparent' %>"
                            data-type="bar">
                            <svg width="20" height="20" class="max-[350px]:w-4 max-[350px]:h-4" viewBox="0 0 20 20">
                                <line x1="4" y1="18" x2="4" y2="12" stroke="white" stroke-linecap="round"
                                    stroke-width="4"></line>
                                <line x1="10" y1="18" x2="10" y2="8" stroke="white" stroke-linecap="round"
                                    stroke-width="4">
                                </line>
                                <line x1="16" y1="18" x2="16" y2="4" stroke="white" stroke-linecap="round"
                                    stroke-width="4">
                                </line>
                            </svg>
                            Bar
                        </button>
                        <button id="chartBtn"
                            onclick="changeChart('line'); document.querySelectorAll('#lineSvg animate').forEach(a => a.beginElement())"
                            class="flex flex-row items-center justify-center max-[350px]:px-2 max-[350px]:py-1 max-[350px]:text-xs gap-1 px-4 py-2 text-sm font-semibold border border-white/50 rounded-sm <%= active === 'line' ? 'bg-black' : 'bg-transparent' %>"
                            data-type="line">
                            <svg width="20" height="20" class="max-[350px]:w-4 max-[350px]:h-4" viewBox="0 0 20 20">
                                <polyline points="2,18 5,10 9,14 13,8 17,13" stroke="white" stroke-width="2"
                                    stroke-linecap="round" fill="none" stroke-linejoin="round"></polyline>
                            </svg>
                            Line
                        </button>
                        <button id="chartBtn"
                            onclick="changeChart('pie'); document.querySelectorAll('#pieSvg animate').forEach(a => a.beginElement())"
                            class="flex flex-row items-center justify-center gap-1 max-[350px]:px-2 max-[350px]:py-1 max-[350px]:text-xs px-4 py-2 text-sm font-semibold border border-white/50 rounded-sm <%= active === 'pie' ? 'bg-black' : 'bg-transparent' %>"
                            data-type="pie">
                            <svg class="bg-white rounded-full max-[350px]:w-4 max-[350px]:h-4" width="20" height="20"
                                viewBox="0 0 20 20">
                                <circle cx="10" cy="10" r="3.7" fill="none" stroke="#2e2e2c" stroke-dasharray="18 20"
                                    stroke-width="8"></circle>
                            </svg>
                            Pie
                        </button>
                    </div>
                    <div id="typeCharts" class="flex mt-4 items-center justify-center w-full h-full">
                        <!-- graph accordingly -->
                        <% const vals=item.info.map(d=> d.value);
                            const maxVal = Math.max(...vals);
                            const chartH = 200; let gap; let startX; let colors; %>

                            <!-- bar -->
                            <div data-type="bar"
                                class="w-[90%] mt-8 h-full <%= active === 'bar' ? 'block' : 'hidden' %>">
                                <% const barW=Math.min(60, Math.floor(520 / vals.length) - 20); gap=Math.floor(520 /
                                    vals.length); startX=80; %>
                                    <!-- <svg width="100%" height="100%" viewBox="0 0 680 280">
                                        <line x1="60" y1="30" x2="640" y2="30" stroke="rgba(255,255,255,0.06)"
                                            stroke-width="" />
                                        <line x1="60" y1="80" x2="640" y2="80" stroke="rgba(255,255,255,0.06)"
                                            stroke-width="1" />
                                        <line x1="60" y1="130" x2="640" y2="130" stroke="rgba(255,255,255,0.06)"
                                            stroke-width="1" />
                                        <line x1="60" y1="180" x2="640" y2="180" stroke="rgba(255,255,255,0.06)"
                                            stroke-width="1" />
                                        <line x1="60" y1="230" x2="640" y2="230" stroke="rgba(255,255,255,0.12)"
                                            stroke-width="1" />
                                        <% colors=['#7f77dd','#1d9e75','#d85a30','#ba7517','#888780','#3266ad','#639922'];
                                            %>
                                            <% item.info.forEach((d, i)=> {
                                                const barH = Math.round((d.value / maxVal) * chartH);
                                                const x = startX + i * gap;
                                                const y = 230 - barH;
                                                const cx = x + barW / 2;
                                                const color = colors[i % colors.length];
                                                %>
                                                <rect x="<%= x %>" y="<%= y %>" width="<%= barW %>" height="0" rx="4"
                                                    fill="<%= color %>cc">
                                                    <animate attributeName="height" from="0%" to="<%= barH %>" dur="1s"
                                                        begin="chartBtn.click" fill="freeze" />
                                                    <animate attributeName="y" from="230" to="<%= y %>" dur="1s"
                                                        begin="chartBtn.click" fill="freeze" />
                                                </rect>
                                                <text x="<%= cx %>" y="<%= y - 8 %>" text-anchor="middle" font-size="12"
                                                    font-weight="700" fill="<%= color %>">
                                                    <%= d.value %>
                                                        <%= item.unit %>
                                                </text>
                                                <text x="<%= cx %>" y="248" text-anchor="middle" font-size="12"
                                                    fill="#aaa">
                                                    <%= d.label %>
                                                </text>

                                                <% }) %>
                                    </svg> -->
                                    <svg id="barSvg" width="100%" height="100%" viewBox="0 0 680 280">
                                        <line x1="60" y1="30" x2="640" y2="30" stroke="rgba(255,255,255,0.06)"
                                            stroke-width="1" />
                                        <line x1="60" y1="80" x2="640" y2="80" stroke="rgba(255,255,255,0.06)"
                                            stroke-width="1" />
                                        <line x1="60" y1="130" x2="640" y2="130" stroke="rgba(255,255,255,0.06)"
                                            stroke-width="1" />
                                        <line x1="60" y1="180" x2="640" y2="180" stroke="rgba(255,255,255,0.06)"
                                            stroke-width="1" />
                                        <line x1="60" y1="230" x2="640" y2="230" stroke="rgba(255,255,255,0.12)"
                                            stroke-width="1" />

                                        <% colors=['#7f77dd','#1d9e75','#d85a30','#ba7517','#888780','#3266ad','#639922'];
                                            %>
                                            <% item.info.forEach((d, i)=> {
                                                const barH = Math.round((d.value / maxVal) * chartH);
                                                const x = startX + i * gap;
                                                const y = 230 - barH;
                                                const cx = x + barW / 2;
                                                const color = colors[i % colors.length];
                                                const delay = i * 0.1 + 's';
                                                %>
                                                <!-- bar grows up -->
                                                <rect x="<%= cx - barW/2 %>" y="230" width="<%= barW %>" height="0"
                                                    rx="4" fill="<%= color %>cc">
                                                    <animate attributeName="height" from="0" to="<%= barH %>" dur="0.8s"
                                                        begin="<%= delay %>" fill="freeze" calcMode="spline"
                                                        keySplines="0 0 0.2 1" keyTimes="0;1" />
                                                    <animate attributeName="y" from="230" to="<%= y %>" dur="0.8s"
                                                        begin="<%= delay %>" fill="freeze" calcMode="spline"
                                                        keySplines="0 0 0.2 1" keyTimes="0;1" />
                                                </rect>

                                                <!-- value label fades in after bar -->
                                                <text x="<%= cx %>" y="<%= y - 8 %>" text-anchor="middle" font-size="12"
                                                    font-weight="700" fill="<%= color %>" opacity="0">
                                                    <%= d.value %>
                                                        <%= item.unit %>
                                                            <animate attributeName="opacity" from="0" to="1" dur="0.3s"
                                                                begin="<%= (i * 0.1 + 0.7) + 's' %>" fill="freeze" />
                                                </text>

                                                <!-- label fades in same time as value -->
                                                <text x="<%= cx %>" y="248" text-anchor="middle" font-size="12"
                                                    fill="#aaa" opacity="0">
                                                    <%= d.label %>
                                                        <animate attributeName="opacity" from="0" to="1" dur="0.3s"
                                                            begin="<%= (i * 0.1 + 0.7) + 's' %>" fill="freeze" />
                                                </text>
                                                <% }) %>
                                    </svg>
                            </div>
                            <!-- line -->
                            <div data-type="line"
                                class="w-[90%] mt-8 h-full <%= active === 'line' ? 'block' : 'hidden' %>">
                                <% gap=Math.floor(520 / (item.info.length - 1)); startX=110; const
                                    points=item.info.map((d, i)=> {
                                    const x = startX + i * gap;
                                    const y = 230 - Math.round((d.value / maxVal) * chartH);
                                    return { x, y, label: d.label, value: d.value };
                                    });
                                    const polyPts = points.map(p => p.x + ',' + p.y).join(' ');

                                    let lineLen = 0;
                                    for (let i = 1; i < points.length; i++) { const dx=points[i].x - points[i-1].x;
                                        const dy=points[i].y - points[i-1].y; lineLen +=Math.sqrt(dx*dx + dy*dy); } %>
                                        <svg id="lineSvg" width="100%" height="100%" viewBox="0 0 680 280">
                                            <line x1="60" y1="30" x2="640" y2="30" stroke="rgba(255,255,255,0.06)"
                                                stroke-width="1" />
                                            <line x1="60" y1="80" x2="640" y2="80" stroke="rgba(255,255,255,0.06)"
                                                stroke-width="1" />
                                            <line x1="60" y1="130" x2="640" y2="130" stroke="rgba(255,255,255,0.06)"
                                                stroke-width="1" />
                                            <line x1="60" y1="180" x2="640" y2="180" stroke="rgba(255,255,255,0.06)"
                                                stroke-width="1" />
                                            <line x1="60" y1="230" x2="640" y2="230" stroke="rgba(255,255,255,0.12)"
                                                stroke-width="1" />

                                            <polyline points="<%- polyPts %>" fill="none" stroke="#7f77dd"
                                                stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"
                                                stroke-dasharray="<%= lineLen %>" stroke-dashoffset="<%= lineLen %>">
                                                <animate attributeName="stroke-dashoffset" from="<%= lineLen %>" to="0"
                                                    dur="1.2s" begin="0s" fill="freeze" calcMode="spline"
                                                    keySplines="0.4 0 0.2 1" keyTimes="0;1" />
                                            </polyline>

                                            <% points.forEach((p, i)=> {
                                                const dotDelay = (i * (1.2 / points.length)).toFixed(2) + 's';
                                                const textDelay = (i * (1.2 / points.length) + 0.15).toFixed(2) + 's';
                                                %>
                                                <circle cx="<%= p.x %>" cy="<%= p.y %>" r="0" fill="#7f77dd">
                                                    <animate attributeName="r" from="0" to="6" dur="0.25s"
                                                        begin="<%= dotDelay %>" fill="freeze" calcMode="spline"
                                                        keySplines="0.2 0 0.2 1.4" keyTimes="0;1" />
                                                </circle>
                                                <circle cx="<%= p.x %>" cy="<%= p.y %>" r="6" fill="#7f77dd"
                                                    opacity="0">
                                                    <animate attributeName="opacity" from="0" to="1" dur="0.25s"
                                                        begin="<%= dotDelay %>" fill="freeze" />
                                                </circle>

                                                <text x="<%= p.x %>" y="<%= p.y - 12 %>" text-anchor="middle"
                                                    font-size="12" font-weight="700" fill="#7f77dd" opacity="0">
                                                    <%= p.value %>
                                                        <%= item.unit %>
                                                            <animate attributeName="opacity" from="0" to="1" dur="0.2s"
                                                                begin="<%= textDelay %>" fill="freeze" />
                                                </text>

                                                <text x="<%= p.x %>" y="248" text-anchor="middle" font-size="12"
                                                    fill="#aaa" opacity="0">
                                                    <%= p.label %>
                                                        <animate attributeName="opacity" from="0" to="1" dur="0.2s"
                                                            begin="<%= dotDelay %>" fill="freeze" />
                                                </text>
                                                <% }) %>
                                        </svg>
                            </div>
                            <!-- pie -->
                            <div data-type="pie" class="w-[90%] h-full <%= active === 'pie' ? 'block' : 'hidden' %>">
                                <% total=vals.reduce((a, b)=> a + b, 0);
                                    colors = ['#7f77dd','#1d9e75','#d85a30','#ba7517','#888780','#3266ad','#639922'];
                                    let offset = 0;
                                    const scale = 100 / total;
                                    const slices = item.info.map((d, i) => {
                                    const scaled = d.value * scale;
                                    const dashoffset = -offset;
                                    offset += scaled;
                                    return { scaled, dashoffset, color: colors[i % colors.length], label: d.label,
                                    value:
                                    d.value };
                                    }); %>
                                    <svg id="pieSvg" width="100%" height="100%" viewBox="0 0 200 115">
                                        <% slices.forEach((s, i)=> {
                                            const sliceDelay = (i * 0.15).toFixed(2) + 's';
                                            %>
                                            <circle cx="80" cy="40" r="15.9" fill="none" stroke="<%= s.color %>"
                                                stroke-width="18" stroke-dasharray="0 100"
                                                stroke-dashoffset="<%= s.dashoffset.toFixed(1) %>">
                                                <title>
                                                    <%= s.label %>: <%= s.value %>
                                                </title>
                                                <animate attributeName="stroke-dasharray" from="0 100"
                                                    to="<%= s.scaled.toFixed(1) %> <%= (100 - s.scaled).toFixed(1) %>"
                                                    dur="0.6s" begin="<%= sliceDelay %>" fill="freeze" calcMode="spline"
                                                    keySplines="0.4 0 0.2 1" keyTimes="0;1" />
                                            </circle>
                                            <% }) %>

                                                <text x="80" y="41" font-size="2" font-weight="700" fill="white"
                                                    text-anchor="middle" opacity="0">
                                                    <%= item.unit%>
                                                        <animate attributeName="opacity" from="0" to="1" dur="0.3s"
                                                            begin="<%= (slices.length * 0.15).toFixed(2) + 's' %>"
                                                            fill="freeze" />
                                                </text>

                                                <% const lineHeight=100 / item.info.length; %>
                                                    <% item.info.forEach((d, i)=> {
                                                        const y = i * lineHeight + lineHeight / 2;
                                                        const legendDelay = (slices.length * 0.15 + i * 0.1).toFixed(2)
                                                        + 's';
                                                        %>
                                                        <rect x="130" y="<%= y %>" width="4" height="4" rx="1"
                                                            fill="<%= colors[i % colors.length] %>" opacity="0">
                                                            <animate attributeName="opacity" from="0" to="1" dur="0.2s"
                                                                begin="<%= legendDelay %>" fill="freeze" />
                                                        </rect>

                                                        <text x="136" y="<%= y+3 %>" font-size="3" font-weight="700"
                                                            fill="white" opacity="0">
                                                            <%= d.label %>
                                                                <animate attributeName="opacity" from="0" to="1"
                                                                    dur="0.2s" begin="<%= legendDelay %>"
                                                                    fill="freeze" />
                                                        </text>

                                                        <text x="180" y="<%= y+3 %>" font-size="3" font-weight="700"
                                                            fill="white" text-anchor="end" opacity="0">
                                                            <%= d.value %>
                                                                <%= item.unit%>
                                                                    <animate attributeName="opacity" from="0" to="1"
                                                                        dur="0.2s" begin="<%= legendDelay %>"
                                                                        fill="freeze" />
                                                        </text>

                                                        <line x1="130" x2="180" y1="<%= y+5 %>" y2="<%= y+5 %>"
                                                            stroke="white" stroke-width="1" stroke-linecap="round"
                                                            opacity="0">
                                                            <animate attributeName="opacity" from="0" to="1" dur="0.2s"
                                                                begin="<%= legendDelay %>" fill="freeze" />
                                                        </line>

                                                        <line x1="130" x2="130" y1="<%= y+5 %>" y2="<%= y+5 %>"
                                                            stroke="<%= colors[i % colors.length] %>" stroke-width="1"
                                                            stroke-linecap="round">
                                                            <animate attributeName="x2" from="130"
                                                                to="<%= 130 + ((d.value / maxVal) * 40) %>" dur="0.4s"
                                                                begin="<%= legendDelay %>" fill="freeze"
                                                                calcMode="spline" keySplines="0.4 0 0.2 1"
                                                                keyTimes="0;1" />
                                                        </line>
                                                        <% }) %>
                                    </svg>
                            </div>
                    </div>
            </div>
            <div class="flex flex-row gap-4">
                <button
                    onclick="document.querySelectorAll('#barSvg animate').forEach(a => a.beginElement()); document.querySelectorAll('#lineSvg animate').forEach(a => a.beginElement()); document.querySelectorAll('#pieSvg animate').forEach(a => a.beginElement())"
                    class="flex flex-row items-center justify-center gap-1 px-4 py-2 text-sm font-semibold border border-white/50 rounded-sm max-[350px]:text-xs max-[350px]:px-2 max-[350px]:py-1">
                    <svg width="15" height="15" viewBox="0 0 20 20">
                        <line x1="3" y1="9" x2="6" y2="11" stroke="white" stroke-width="2" stroke-linecap="round"
                            fill="none">
                        </line>
                        <line x1="3" y1="10" x2="0" y2="11" stroke="white" stroke-width="2" stroke-linecap="round"
                            fill="none">
                        </line>
                        <circle cx="10" cy="10" r="8" stroke="white" stroke-width="2" stroke-dasharray="45 5"
                            stroke-dashoffset="18" fill="none"></circle>
                    </svg>
                    Replay animation
                </button>
                <% let nextId=(Number(item.id) < data.length) ? Number(item.id) + 1 : 1; %>
                    <a href="/infographic/<%= nextId %>">
                        <button
                            class="flex flex-row items-center justify-center max-[350px]:px-2 max-[350px]:py-1 gap-1 px-4 py-2 text-sm max-[350px]:text-xs font-semibold border border-white/50 rounded-sm">Next
                            story
                            <svg width="10" height="10" viewBox="0 0 20 20">
                                <line x1="16" y1="10" x2="6" y2="2" stroke="white" stroke-width="4"
                                    stroke-linecap="round" fill="none">
                                </line>
                                <line x1="16" y1="10" x2="6" y2="18" stroke="white" stroke-width="4"
                                    stroke-linecap="round" fill="none">
                                </line>
                            </svg>
                        </button>
                    </a>
            </div>
        </section>

</body>

</html>