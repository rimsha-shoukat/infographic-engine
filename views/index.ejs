<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Animated data story</title>
    <link href="/css/style.css" rel="stylesheet">
    <script src="/js/index.js"></script>
</head>

<body>
    <!-- top navbar -->
    <nav class="w-full h-auto flex flex-row items-center justify-between p-3 border-b border-b-white/50 bg-[#2e2e2c]">
        <div class="flex flex-row gap-2 items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 20 20" class="fill-current">
                <rect width="8" height="8" x="2" y="2" rx="2" ry="2" fill="#6963a6"></rect>
                <rect width="8" height="8" x="12" y="2" rx="2" ry="2" fill="#8884b0"></rect>
                <rect width="8" height="8" x="12" y="12" rx="2" ry="2" fill="#9e9cb8"></rect>
                <rect width="8" height="8" x="2" y="12" rx="2" ry="2" fill="#8884b0"></rect>
            </svg>
            <h1 class="text-md font-semibold">Infograph</h1>
        </div>
        <button class="px-2 text-xs border border-white/50 rounded-sm bg-black">
            <%= data.length %>
                stories
        </button>
    </nav>
    <!-- landing -->
    <section class="w-full h-auto flex flex-row items-center justify-between bg-[#2e2e2c]">
        <div class="w-auto h-auto p-14">
            <button
                class="text-md rounded-md tracking-wider font-semibold py-1 px-3 bg-[#b2b1bd] text-[#5a5582] line-clamp-1">Data
                storytelling
                engine</button>
            <h1 class="text-[2.45rem] tracking-wide font-semibold line-clamp-1 my-2">Numbers that tell a story</h1>
            <h3 class="line-clamp-2 text-white/50 text-[1.6rem] tracking-wide">Pick a dataset and watch it come
                alive --
                animated
                charts built from
                scratch, no
                libraries.</h3>
            <button onclick="scrollToStories()"
                class="border-[1.5px] font-semibold tracking-wide border-white/50 rounded-lg px-6 py-2 mt-10 flex flex-row items-center justify-center">Explore
                stories
                <svg width="22" height="20" viewBox="0 0 22 20">
                    <line x1="8" y1="12" x2="20" y2="12" fill="white" stroke="white" stroke-width="2"
                        stroke-linecap="round"></line>
                    <line x1="20" y1="12" x2="15" y2="8" fill="white" stroke="white" stroke-width="2"
                        stroke-linecap="round"></line>
                    <line x1="20" y1="12" x2="15" y2="16" fill="white" stroke="white" stroke-width="2"
                        stroke-linecap="round"></line>
                </svg>
            </button>
        </div>
        <div class="w-[50%] h-auto flex items-center justify-center">
            <svg width="20rem" height="15rem" viewBox="0 0 200 150">
                <line x1="11" y1="140" x2="160" y2="140" stroke="#666482" stroke-width="2" fill="none"></line>
                <rect width="25" height="70" x="12" y="68" rx="5" ry="5" fill="#a4a3ad"></rect>
                <rect width="25" height="85" x="43" y="53" rx="5" ry="5" fill="#918fa8"></rect>
                <rect width="25" height="102" x="74" y="36" rx="5" ry="5" fill="#7d7aa3"></rect>
                <rect width="25" height="75" x="104" y="63" rx="5" ry="5" fill="#918fa8"></rect>
                <rect width="25" height="90" x="134" y="48" rx="5" ry="5" fill="#a4a3ad"></rect>
                <polyline points="24,68 55,53 86,36 115,63 146,48" stroke-width="2" stroke="#5e5999" fill="none">
                </polyline>
                <circle cx="24" cy="68" r="4" fill="#5e5999"></circle>
                <circle cx="55" cy="53" r="4" fill="#5e5999"></circle>
                <circle cx="86" cy="36" r="4" fill="#5e5999"></circle>
                <circle cx="115" cy="63" r="4" fill="#5e5999"></circle>
                <circle cx="146" cy="48" r="4" fill="#5e5999"></circle>
            </svg>
        </div>
    </section>
    <!-- cards -->
    <section class="bg-black p-8">
        <div class="flex flex-row items-center justify-between">
            <h2 class="font-semibold text-[1.2rem] tracking-wide">All stories</h2>
            <div class="flex flex-row items-center justify-center gap-3 font-semibold">
                <button class="border-2 border-white/50 rounded-md px-4 py-1">All</button>
                <button class="border-2 border-white/50 rounded-md px-4 py-1">Bar</button>
                <button class="border-2 border-white/50 rounded-md px-4 py-1">Line</button>
                <button class="border-2 border-white/50 rounded-md px-4 py-1">Pie</button>
            </div>
        </div>

        <!-- reusable card thumbnails -->
        <svg style="display: none;">
            <!-- bar chart -->
            <symbol id="barChart">
                <line x1="11" y1="130" x2="160" y2="130" stroke="#a9a8ba" stroke-width="2" fill="none"></line>
                <rect width="25" height="60" x="12" y="68" rx="5" ry="5" fill="#7e79ad"></rect>
                <rect width="25" height="75" x="43" y="53" rx="5" ry="5" fill="#726ca8"></rect>
                <rect width="25" height="92" x="74" y="36" rx="5" ry="5" fill="#6560a6"></rect>
                <rect width="25" height="65" x="104" y="63" rx="5" ry="5" fill="#6f6aa8"></rect>
                <rect width="25" height="80" x="134" y="48" rx="5" ry="5" fill="#7d78ad"></rect>
            </symbol>
        </svg>
        <svg style="display: none;">
            <!-- line chart -->
            <symbol id="lineChart">
                <line x1="11" y1="120" x2="160" y2="120" stroke="#a1b5ae" stroke-width="4" fill="none"></line>
                <circle r="5" cx="18" cy="96" fill="#207a5e"></circle>
                <circle r="5" cx="40" cy="70" fill="#207a5e"></circle>
                <circle r="5" cx="70" cy="85" fill="#207a5e"></circle>
                <circle r="5" cx="95" cy="50" fill="#207a5e"></circle>
                <circle r="5" cx="120" cy="75" fill="#207a5e"></circle>
                <circle r="5" cx="148" cy="62" fill="#207a5e"></circle>
                <polyline points="18,96 40,70 70,85 95,50 120,75 148,62" stroke-width="3" stroke="#207a5e" fill="none">
                </polyline>
            </symbol>
        </svg>
        <svg style="display: none;">
            <!-- pie chart -->
            <symbol id="pieChart">
                <circle cx="55" cy="30" r="10" fill="2e2e2c"></circle>
                <circle cx="55" cy="30" r="15.9" fill="none" stroke-dasharray="40 60" stroke-dashoffset="0"
                    stroke="#8e5d1b" stroke-width="10"></circle>
                <circle cx="55" cy="30" r="15.9" fill="none" stroke-dasharray="25 75" stroke-dashoffset="-40"
                    stroke="#b37a25" stroke-width="10"></circle>
                <circle cx="55" cy="30" r="15.9" fill="none" stroke-dasharray="15 85" stroke-dashoffset="-65"
                    stroke="#ba965d" stroke-width="10"></circle>
                <circle cx="55" cy="30" r="15.9" fill="none" stroke-dasharray="10 90" stroke-dashoffset="-80"
                    stroke="#a07c4a" stroke-width="10"></circle>
            </symbol>
        </svg>

        <div id="stories" class="flex flex-row items-start justify-between flex-wrap mt-6">
            <% data.forEach(item=> {
                <!-- logic to pic style -->
                let type = item.chartType[0];
                let bgColor, textColor, symbolId, vBox;
                if(type === "bar"){
                bgColor = "#b1b1bd"; textColor = "#6560a6"; symbolId = "#barChart"; vBox = "0 0 180 160";
                } else if(type === "line"){
                bgColor = "#a9b8b2"; textColor = "#207a5e"; symbolId = "#lineChart"; vBox = "0 0 180 160";
                }else if(type === "pie"){
                bgColor = "#bab2a4"; textColor = "#8f5d1b"; symbolId = "#pieChart"; vBox = "0 0 110 60";
                } %>

                <div class="flex flex-col bg-[#2e2e2c] w-92 h-auto border border-white/40 rounded-xl mb-4">
                    <!-- Dynamic ViewBox and Background -->
                    <svg width="100%" height="180" viewBox="<%= vBox %>" class="rounded-t-xl bg-[<%= bgColor %>]">
                        <use href="<%= symbolId %>"></use>
                    </svg>

                    <div class="w-full h-50 p-5">
                        <button
                            class="px-3 bg-[<%= bgColor %>] text-[<%= textColor %>] tracking-wide font-semibold rounded-md capitalize">
                            <%= type %> chart
                        </button>

                        <h2 class="line-clamp-1 font-bold text-[1.3rem] mt-2 tracking-wide">
                            <%= item.title %>
                        </h2>
                        <h4 class="line-clamp-2 font-semibold text-[1rem] text-white/50">
                            <%= item.insight %>
                        </h4>

                        <div class="w-full flex flex-row items-center justify-between mt-5">
                            <h4 class="font-semibold text-white/50">
                                <%= item.info.length %> data points - <%= item.unit %>
                            </h4>
                            <svg width="30" height="30" viewBox="0 0 100 100" class="bg-[#262624] rounded-full">
                                <line x1="35" y1="50" x2="65" y2="50" stroke="white" stroke-width="5" fill="none"
                                    stroke-linecap="round"></line>
                                <line x1="65" y1="50" x2="50" y2="38" stroke="white" stroke-width="5" fill="none"
                                    stroke-linecap="round"></line>
                                <line x1="65" y1="50" x2="50" y2="62" stroke="white" stroke-width="5" fill="none"
                                    stroke-linecap="round"></line>
                            </svg>
                        </div>
                    </div>
                </div>
                <% }) %>
        </div>
    </section>
    <!-- data count -->
    <footer class="flex flex-row items-center justify-between px-8 bg-black pb-6">
        <div class="flex flex-col w-92 items-center justify-center p-4 rounded-xl bg-[#2e2e2c]">
            <h1 class="font-semibold text-[1.5rem]">
                <%= data.length %>
            </h1>
            <h3 class="text-white/50 font-semibold">Total stories</h3>
        </div>
        <div class="flex flex-col w-92 items-center justify-center p-4 rounded-xl bg-[#2e2e2c]">
            <h1 class="font-semibold text-[1.5rem]">3</h1>
            <h3 class="text-white/50 font-semibold">Chart types</h3>
        </div>
        <div class="flex flex-col w-92 items-center justify-center p-4 rounded-xl bg-[#2e2e2c]">
            <h1 class="font-semibold text-[1.5rem]">
                <%= data.reduce((acc, curr)=> acc + (curr.info ? curr.info.length : 0), 0) %>
            </h1>
            <h3 class="text-white/50 font-semibold">Data points</h3>
        </div>
    </footer>
</body>

</html>