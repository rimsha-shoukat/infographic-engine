<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Animated data story</title>
    <link href="/css/style.css" rel="stylesheet">
</head>

<body>
    <!-- top navbar -->
    <nav class="w-full h-auto flex flex-row items-center justify-between p-3 border-b border-b-white/50 bg-[#2e2e2c]">
        <div class="flex flex-row gap-2 items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 20 20" class="fill-current">
                <rect width="8" height="8" x="2" y="2" rx="2" ry="2" fill="#6963a6"></rect>
                <rect width="8" height="8" x="12" y="2" rx="2" ry="2" fill="#8884b0"></rect>
                <rect width="8" height="8" x="12" y="12" rx="2" ry="2" fill="#9e9cb8"></rect>
                <rect width="8" height="8" x="2" y="12" rx="2" ry="2" fill="#8884b0"></rect>
            </svg>
            <h1 class="text-md font-semibold">Infograph</h1>
        </div>
        <button class="px-2 text-xs border border-white/50 rounded-sm bg-black">3
            stories</button>
    </nav>
    <!-- landing -->
    <section class="w-full h-auto flex flex-row items-center justify-between bg-[#2e2e2c]">
        <div class="w-auto h-auto p-14">
            <button
                class="text-md rounded-md tracking-wider font-semibold py-1 px-3 bg-[#b2b1bd] text-[#5a5582] line-clamp-1">Data
                storytelling
                engine</button>
            <h1 class="text-[2.45rem] tracking-wide font-semibold line-clamp-1 my-2">Numbers that tell a story</h1>
            <h3 class="line-clamp-2 text-white/50 text-[1.6rem] tracking-wide">Pick a dataset and watch it come alive --
                animated
                charts built from
                scratch, no
                libraries.</h3>
            <button
                class="border-[1.5px] font-semibold tracking-wide border-white/50 rounded-lg px-6 py-2 mt-10 flex flex-row items-center justify-center">Explore
                stories
                <svg width="22" height="20" viewBox="0 0 22 20">
                    <line x1="8" y1="12" x2="20" y2="12" fill="white" stroke="white" stroke-width="2"
                        stroke-linecap="round"></line>
                    <line x1="20" y1="12" x2="15" y2="8" fill="white" stroke="white" stroke-width="2"
                        stroke-linecap="round"></line>
                    <line x1="20" y1="12" x2="15" y2="16" fill="white" stroke="white" stroke-width="2"
                        stroke-linecap="round"></line>
                </svg>
            </button>
        </div>
        <div class="w-[50%] h-auto flex items-center justify-center">
            <svg width="20rem" height="15rem" viewBox="0 0 200 150">
                <line x1="11" y1="140" x2="160" y2="140" stroke="#666482" stroke-width="2" fill="none"></line>
                <rect width="25" height="70" x="12" y="68" rx="5" ry="5" fill="#a4a3ad"></rect>
                <rect width="25" height="85" x="43" y="53" rx="5" ry="5" fill="#918fa8"></rect>
                <rect width="25" height="102" x="74" y="36" rx="5" ry="5" fill="#7d7aa3"></rect>
                <rect width="25" height="75" x="104" y="63" rx="5" ry="5" fill="#918fa8"></rect>
                <rect width="25" height="90" x="134" y="48" rx="5" ry="5" fill="#a4a3ad"></rect>
                <polyline points="24,68 55,53 86,36 115,63 146,48" stroke-width="2" stroke="#5e5999" fill="none">
                </polyline>
                <circle cx="24" cy="68" r="4" fill="#5e5999"></circle>
                <circle cx="55" cy="53" r="4" fill="#5e5999"></circle>
                <circle cx="86" cy="36" r="4" fill="#5e5999"></circle>
                <circle cx="115" cy="63" r="4" fill="#5e5999"></circle>
                <circle cx="146" cy="48" r="4" fill="#5e5999"></circle>
            </svg>
        </div>
    </section>
    <!-- cards -->
    <section></section>
    <!-- data count -->
    <footer></footer>
</body>

</html>